---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { PROFILE } from '../data/profile';
import { STATS } from '../data/stats';
import { EXPERIENCE } from '../data/experience';
import { TOOLS } from '../data/tools';
import { PROJECTS } from '../data/projects';

const featured = PROJECTS.slice(0, 4);
---

<BaseLayout ogImage="/og/home.png">
  <main class="relative min-h-screen">
    <div class="fixed inset-0 bg-grid opacity-40 pointer-events-none"></div>
    <div
      class="fixed -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-35 pointer-events-none"
      style="background: conic-gradient(from 180deg, #22d3ee, #60a5fa, #a78bfa, #22d3ee);"
    ></div>

    <div class="relative mx-auto max-w-5xl px-6 py-12">
      <SiteHeader />

      <!-- Hero -->
      <section id="about" class="mt-16">
        <div class="grid gap-12 lg:grid-cols-[1fr_280px] lg:items-center">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-4 py-1.5 text-sm text-cyan-400">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
              </span>
              {PROFILE.availability}
            </div>
            <h1 class="text-5xl font-bold tracking-tight lg:text-6xl">
              {PROFILE.role}
              <span class="block text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500">
                {PROFILE.tagline}
              </span>
            </h1>
            <p class="max-w-2xl text-lg text-slate-300 leading-relaxed">{PROFILE.headline}</p>
            <div class="flex flex-wrap gap-4">
              <a href="/projects" class="group relative inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-6 py-3 text-sm font-semibold text-slate-950 hover:bg-cyan-400 transition-all">
                Lihat projects
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
              <a href="/blog" class="rounded-xl border border-slate-700 px-6 py-3 text-sm font-semibold hover:border-slate-500 hover:bg-slate-800/50 transition-all">
                Baca blog
              </a>
              <a href={PROFILE.contacts.github.href} class="rounded-xl border border-slate-700 px-6 py-3 text-sm font-semibold hover:border-slate-500 hover:bg-slate-800/50 transition-all" target="_blank" rel="noreferrer">
                GitHub
              </a>
              <a href={PROFILE.contacts.linkedin.href} class="rounded-xl border border-slate-700 px-6 py-3 text-sm font-semibold hover:border-slate-500 hover:bg-slate-800/50 transition-all" target="_blank" rel="noreferrer">
                LinkedIn
              </a>
            </div>
          </div>

          <div class="floaty mx-auto lg:mx-0">
            <div class="relative grid h-64 w-64 place-items-center rounded-3xl border border-slate-700 bg-slate-900/40 shadow-2xl overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/20 via-blue-500/10 to-purple-500/20"></div>
              <div class="relative text-center">
                <div class="grid h-28 w-28 place-items-center rounded-2xl bg-slate-950/60 ring-1 ring-slate-700 backdrop-blur-sm mx-auto overflow-hidden">
                  <img
                    src="/images/profile-512.jpg"
                    alt={`${PROFILE.name} photo`}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <p class="mt-4 text-center text-sm text-slate-400">{PROFILE.role}</p>
                <p class="text-xs text-slate-500">{PROFILE.location}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Stats -->
      <section class="mt-20">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {STATS.map((stat) => (
            <div class="rounded-2xl border border-slate-800 bg-slate-900/30 p-6 text-center hover:border-slate-700 transition-all hover:bg-slate-800/30">
              <div class="text-3xl font-bold text-cyan-400">{stat.value}</div>
              <div class="mt-1 text-sm text-slate-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Experience -->
      <section id="experience" class="mt-20">
        <h2 class="text-3xl font-bold mb-8">Experience</h2>
        <div class="space-y-6">
          {EXPERIENCE.map((exp) => (
            <div class="relative pl-8 border-l-2 border-slate-800 hover:border-cyan-500/50 transition-colors">
              <div class="absolute -left-[9px] top-0 h-4 w-4 rounded-full bg-slate-800 border-2 border-cyan-500"></div>
              <div class="rounded-2xl border border-slate-800 bg-slate-900/30 p-6 hover:border-slate-700 transition-all">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    <h3 class="text-xl font-semibold">{exp.role}</h3>
                    <p class="text-cyan-400">{exp.company}</p>
                  </div>
                  <span class="text-sm text-slate-500 bg-slate-800/50 px-3 py-1 rounded-full">{exp.period}</span>
                </div>
                <p class="mt-3 text-slate-300">{exp.description}</p>
                <ul class="mt-4 flex flex-wrap gap-2">
                  {exp.highlights.map((h) => (
                    <li class="text-xs bg-slate-800/70 text-slate-300 px-3 py-1.5 rounded-full">{h}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tools -->
      <section class="mt-20">
        <h2 class="text-3xl font-bold mb-8">Tools & Technologies</h2>
        <div class="grid grid-cols-4 md:grid-cols-8 gap-4">
          {TOOLS.map((tool) => (
            <div class="group rounded-2xl border border-slate-800 bg-slate-900/30 p-4 text-center hover:border-cyan-500/50 hover:bg-slate-800/50 transition-all cursor-default" title={tool.name}>
              <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{tool.icon}</div>
              <div class="text-xs text-slate-400">{tool.name}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Featured Projects -->
      <section class="mt-20">
        <div class="flex items-end justify-between gap-6 mb-8">
          <div>
            <h2 class="text-3xl font-bold">Featured Projects</h2>
            <p class="mt-2 text-slate-400">Pilihan case study & automation.</p>
          </div>
          <a href="/projects" class="text-sm text-cyan-400 hover:text-cyan-300">Lihat semua →</a>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {featured.map((p) => (
            <a href={`/projects/${p.slug}`} class="group rounded-2xl border border-slate-800 bg-slate-900/30 p-6 hover:border-cyan-500/30 hover:bg-slate-800/30 transition-all">
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-xl font-semibold group-hover:text-cyan-400 transition-colors">{p.title}</h3>
                <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-300">{p.status}</span>
              </div>
              <p class="mt-3 text-slate-300">{p.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {p.tags.map((t) => (
                  <span class="rounded-full bg-slate-800/70 px-3 py-1 text-xs text-slate-200">{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="mt-20">
        <div class="rounded-3xl border border-slate-800 bg-slate-900/30 p-8 md:p-12">
          <div class="grid gap-8 md:grid-cols-2 items-center">
            <div>
              <h2 class="text-3xl font-bold mb-4">Let’s work together</h2>
              <p class="text-slate-400 mb-6">Buka untuk proyek konsultasi network infrastructure, automation, atau ISP operations.</p>

              <!-- Formspree Contact Form (static-friendly) -->
              <form
                class="grid gap-4"
                method="POST"
                action="https://formspree.io/f/mreydzkq"
              >
                <input type="text" name="name" placeholder="Nama" class="w-full rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-sm outline-none focus:border-cyan-500/60" required />
                <input type="email" name="email" placeholder="Email" class="w-full rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-sm outline-none focus:border-cyan-500/60" required />
                <textarea name="message" placeholder="Pesan" rows="4" class="w-full rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-sm outline-none focus:border-cyan-500/60" required></textarea>

                <!-- honeypot -->
                <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

                <div class="flex flex-wrap gap-3 items-center">
                  <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-6 py-3 text-sm font-semibold text-slate-950 hover:bg-cyan-400 transition-all">
                    Kirim pesan
                  </button>
                  <a href={PROFILE.contacts.email.href} class="text-sm text-slate-400 hover:text-cyan-400">
                    atau kirim email langsung
                  </a>
                </div>

              </form>
            </div>
            <div class="grid gap-4">
              <a class="flex items-center gap-4 rounded-xl border border-slate-800 bg-slate-950/50 p-4 hover:border-slate-700 transition-all" href={PROFILE.contacts.telegram.href} target="_blank" rel="noreferrer">
                <span class="text-2xl">💬</span>
                <div>
                  <div class="text-sm text-slate-500">Telegram</div>
                  <div class="font-semibold">{PROFILE.contacts.telegram.label}</div>
                </div>
              </a>
              <a class="flex items-center gap-4 rounded-xl border border-slate-800 bg-slate-950/50 p-4 hover:border-slate-700 transition-all" href={PROFILE.contacts.whatsapp.href} target="_blank" rel="noreferrer">
                <span class="text-2xl">📱</span>
                <div>
                  <div class="text-sm text-slate-500">WhatsApp</div>
                  <div class="font-semibold">{PROFILE.contacts.whatsapp.label}</div>
                </div>
              </a>
              <a class="flex items-center gap-4 rounded-xl border border-slate-800 bg-slate-950/50 p-4 hover:border-slate-700 transition-all" href={PROFILE.contacts.linkedin.href} target="_blank" rel="noreferrer">
                <span class="text-2xl">💼</span>
                <div>
                  <div class="text-sm text-slate-500">LinkedIn</div>
                  <div class="font-semibold">{PROFILE.contacts.linkedin.label}</div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </section>

      <footer class="mt-20 border-t border-slate-800 py-8 text-sm text-slate-500">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <span>© {new Date().getFullYear()} {PROFILE.name}</span>
          <div class="flex items-center gap-4">
            <a href={PROFILE.contacts.linkedin.href} class="hover:text-cyan-400" target="_blank" rel="noreferrer">LinkedIn</a>
            <span class="text-slate-700">•</span>
            <a href="/rss.xml" class="hover:text-cyan-400">RSS</a>
            <span class="text-slate-700">•</span>
            <span class="text-slate-600">Built with Astro + Tailwind</span>
          </div>
        </div>
      </footer>
    </div>
  </main>

  <style is:global>
    html { scroll-behavior: smooth; }
    .bg-grid {
      background-image: radial-gradient(rgba(148, 163, 184, 0.25) 1px, transparent 0);
      background-size: 32px 32px;
      background-position: -8px -8px;
      mask-image: radial-gradient(circle at 50% 0%, black 30%, transparent 70%);
    }
    @media (prefers-reduced-motion: reduce) {
      .floaty { animation: none !important; }
      html { scroll-behavior: auto; }
    }
    .floaty { animation: floaty 8s ease-in-out infinite; }
    @keyframes floaty { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
  </style>
</BaseLayout>

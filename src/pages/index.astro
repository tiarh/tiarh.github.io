                  <a href={p.github} class="text-sm text-cyan-400 hover:text-cyan-300 flex items-center gap-1" target="_blank" rel="noreferrer">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    Source Code
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>

        <!-- Blog -->
        <section id="blog" class="mt-20">
          <h2 class="text-3xl font-bold mb-8">Latest Articles</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {BLOG_POSTS.map((post) => (
              <article class="group rounded-2xl border border-slate-800 bg-slate-900/30 p-6 hover:border-slate-700 transition-all cursor-pointer">
                <div class="flex items-center gap-2 text-xs text-slate-500 mb-3">
                  <time>{post.date}</time>
                  <span>•</span>
                  <span>{post.readTime} read</span>
                </div>
                <h3 class="text-lg font-semibold group-hover:text-cyan-400 transition-colors mb-2">{post.title}</h3>
                <p class="text-sm text-slate-400 mb-4 line-clamp-2">{post.excerpt}</p>
                <div class="flex flex-wrap gap-2">
                  {post.tags.map((t) => (
                    <span class="text-xs bg-slate-800 text-slate-300 px-2 py-1 rounded">{t}</span>

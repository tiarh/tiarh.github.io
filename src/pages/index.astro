---

<html lang="id" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{PROFILE.name} — {PROFILE.role}</title>
    <meta name="description" content={`${PROFILE.name} — ${PROFILE.role}. ${PROFILE.tagline}.`} />
    <meta name="keywords" content="Network Engineer, ISP, NOC, MikroTik, PPPoE, Routing, Indonesia" />
    <meta name="author" content={PROFILE.name} />
    <meta property="og:title" content={`${PROFILE.name} — ${PROFILE.role}`} />
    <meta property="og:description" content={PROFILE.tagline} />
    <meta property="og:type" content="website" />
    <meta name="color-scheme" content="dark light" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <script is:inline>
      // Theme toggle logic
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      if (theme === 'dark') {
        document.body.classList.add('bg-slate-950', 'text-slate-100');
      } else {
        document.body.classList.add('bg-white', 'text-slate-900');
      }
    </script>

    <main class="relative min-h-screen">
      <!-- Animated Background -->
      <div class="fixed inset-0 bg-grid opacity-40 pointer-events-none"></div>
      <div class="fixed -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-35 pointer-events-none" 
           style="background: conic-gradient(from 180deg, #22d3ee, #60a5fa, #a78bfa, #22d3ee);"></div>

      <div class="relative mx-auto max-w-5xl px-6 py-12">
        <!-- Header -->
        <header class="flex items-center justify-between gap-6 sticky top-0 z-50 py-4 backdrop-blur-lg rounded-2xl border border-slate-800/50 bg-slate-950/80 px-6">
          <a href="#" class="font-semibold tracking-tight text-lg">{PROFILE.name}</a>
          <nav class="hidden md:flex gap-6 text-sm">
            <a class="hover:text-cyan-400 transition-colors" href="#about">About</a>
            <a class="hover:text-cyan-400 transition-colors" href="#experience">Experience</a>
            <a class="hover:text-cyan-400 transition-colors" href="#projects">Projects</a>
            <a class="hover:text-cyan-400 transition-colors" href="#blog">Blog</a>
            <a class="hover:text-cyan-400 transition-colors" href="#contact">Contact</a>
          </nav>
          <button id="theme-toggle" class="p-2 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" aria-label="Toggle theme">
            <span class="dark-icon">🌙</span>
            <span class="light-icon hidden">☀️</span>
          </button>
        </header>

        <!-- Hero -->
        <section id="about" class="mt-20">

            </div>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {PROJECTS.map((p) => (
              <article class="group rounded-2xl border border-slate-800 bg-slate-900/30 p-6 hover:border-cyan-500/30 hover:bg-slate-800/30 transition-all">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-xl font-semibold group-hover:text-cyan-400 transition-colors">{p.title}</h3>
                  <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-300">{p.status}</span>
                </div>
                <p class="mt-3 text-slate-300">{p.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {p.tags.map((t) => (
                    <span class="rounded-full bg-slate-800/70 px-3 py-1 text-xs text-slate-200">{t}</span>
                  ))}
                </div>
                <ul class="mt-4 space-y-2">
                  {p.highlights.map((h) => (
                    <li class="flex items-center gap-2 text-sm text-slate-400">
                      <svg class="w-4 h-4 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                      {h}

---
const PROFILE = {
  name: "Ikhtiar Hidayatullah",
  role: "Network Engineer",
  tagline: "ISP NOC • MikroTik • Routing • Monitoring Automation",
  location: "Indonesia",
  contacts: {
    telegram: { label: "@lumayancuk", href: "https://t.me/lumayancuk" },
    whatsapp: { label: "+62 852-3441-5861", href: "https://wa.me/6285234415861" },
    email: { label: "ihidayatullah57@gmail.com", href: "mailto:ihidayatullah57@gmail.com" },
    github: { label: "tiarh", href: "https://github.com/tiarh" },
  },
};

const PROJECTS = [
  {
    title: "ISP PPPoE Platform (MikroTik)",
    status: "Case study",
    tags: ["MikroTik", "PPPoE", "PCQ", "QoS"],
    description:
      "Desain PPPoE server + profile bandwidth (PCQ), queue/limits, dan SOP deployment. Fokus stabil, aman, dan mudah dioperasikan.",
    highlights: [
      "PPPoE profiles & rate limits (PCQ)",
      "Queue parent strategy + basic anti-abuse",
      "Sanitized config snippets + test checklist",
    ],
  },
  {
    title: "Dual-WAN Failover & Load Balancing (PCC + Recursive)",
    status: "Case study",
    tags: ["Routing", "Failover", "PCC"],
    description:
      "Implementasi multi-WAN dengan health-check, recursive routing untuk failover, dan PCC untuk distribusi trafik.",
    highlights: [
      "Recursive route failover + health check",
      "PCC policy routing",
      "Before/after + test scenarios",
    ],
  },
  {
    title: "Monitoring Automation (Skynet Ping Monitoring)",
    status: "Automation",
    tags: ["Playwright", "Reporting", "NOC"],
    description:
      "Auto-generate report per area (DOWN/UP non‑isolir) + last active, output gambar siap kirim ke WA/Telegram.",
    highlights: [
      "Exclude ISOLIR rows",
      "Sampling to catch flapping downs",
      "HTML → Image report",
    ],
  },
  {
    title: "WhatsApp Ops Bot (Scoped to 1 group)",
    status: "Automation",
    tags: ["WhatsApp", "OpenClaw", "Guardrails"],
    description:
      "Bot WA khusus 1 grup untuk monitoring per area + chat ops. Ada allowlist, anti-loop, dan command monitoring AREA.",
    highlights: [
      "Hard allowlist group",
      "Monitoring via areas.json",
      "Anti-spam + timeouts",
    ],
  },
];

const SKILLS = [
  "MikroTik (PPPoE, Queues, PCC)",
  "Routing (OSPF basics, recursive routing)",
  "Monitoring & incident triage",
  "Automation (Python, Playwright, systemd timers)",
];
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{PROFILE.name} — {PROFILE.role}</title>
    <meta
      name="description"
      content={`${PROFILE.name} — ${PROFILE.role}. ${PROFILE.tagline}.`}
    />
    <meta name="color-scheme" content="dark light" />
    <style>
      /* tiny animated background */
      .bg-grid {
        background-image: radial-gradient(rgba(148, 163, 184, 0.25) 1px, transparent 0);
        background-size: 32px 32px;
        background-position: -8px -8px;
        mask-image: radial-gradient(circle at 50% 0%, black 30%, transparent 70%);
      }
      @media (prefers-reduced-motion: reduce) {
        .floaty { animation: none !important; }
      }
      .floaty {
        animation: floaty 8s ease-in-out infinite;
      }
      @keyframes floaty {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-8px); }
      }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100">
    <main class="relative">
      <div class="absolute inset-0 bg-grid opacity-40"></div>
      <div
        class="absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-35"
        style="background: conic-gradient(from 180deg, #22d3ee, #60a5fa, #a78bfa, #22d3ee);"
      ></div>

      <div class="relative mx-auto max-w-5xl px-6 py-12">
        <!-- Header -->
        <header class="flex flex-col gap-10">
          <div class="flex items-center justify-between gap-6">
            <a href="#" class="font-semibold tracking-tight">{PROFILE.name}</a>
            <nav class="flex gap-4 text-sm text-slate-300">
              <a class="hover:text-white" href="#projects">Projects</a>
              <a class="hover:text-white" href="#skills">Skills</a>
              <a class="hover:text-white" href="#contact">Contact</a>
            </nav>
          </div>

          <!-- Hero -->
          <section class="grid gap-8 md:grid-cols-[1fr_240px] md:items-center">
            <div class="space-y-5">
              <p class="text-sm text-slate-300">{PROFILE.location}</p>
              <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">
                {PROFILE.role}
                <span class="block text-slate-300">{PROFILE.tagline}</span>
              </h1>
              <p class="max-w-2xl text-slate-200/90">
                Saya fokus di operasi ISP/NOC: routing, PPPoE, bandwidth management, monitoring, dan otomatisasi.
                Tujuan saya: jaringan stabil, troubleshooting cepat, dan tooling yang bisa dipakai tim.
              </p>
              <div class="flex flex-wrap gap-3">
                <a
                  href="#projects"
                  class="rounded-xl bg-cyan-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-cyan-400"
                >
                  Lihat projects
                </a>
                <a
                  href={PROFILE.contacts.github.href}
                  class="rounded-xl border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-100 hover:border-slate-500"
                  target="_blank"
                  rel="noreferrer"
                >
                  GitHub
                </a>
              </div>
            </div>

            <!-- IH Avatar -->
            <div class="floaty mx-auto">
              <div class="relative grid h-56 w-56 place-items-center rounded-3xl border border-slate-700 bg-slate-900/40 shadow-xl">
                <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-cyan-500/20 via-blue-500/10 to-purple-500/20"></div>
                <div class="relative">
                  <div class="grid h-24 w-24 place-items-center rounded-2xl bg-slate-950/40 ring-1 ring-slate-700">
                    <span class="text-3xl font-bold tracking-tight">IH</span>
                  </div>
                  <p class="mt-4 text-center text-sm text-slate-300">Network Engineer</p>
                </div>
              </div>
            </div>
          </section>
        </header>

        <!-- Projects -->
        <section id="projects" class="mt-16">
          <div class="mb-6 flex items-end justify-between gap-6">
            <div>
              <h2 class="text-2xl font-semibold">Projects</h2>
              <p class="mt-1 text-sm text-slate-300">
                Kumpulan case study & automation yang relevan untuk NOC/ISP.
              </p>
            </div>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            {PROJECTS.map((p) => (
              <article class="rounded-2xl border border-slate-800 bg-slate-900/30 p-5 shadow-sm hover:border-slate-700">
                <div class="flex items-center justify-between gap-3">
                  <h3 class="text-lg font-semibold">{p.title}</h3>
                  <span class="rounded-full border border-slate-700 px-2 py-1 text-xs text-slate-300">{p.status}</span>
                </div>
                <p class="mt-2 text-sm text-slate-200/90">{p.description}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {p.tags.map((t) => (
                    <span class="rounded-full bg-slate-800/70 px-2 py-1 text-xs text-slate-200">{t}</span>
                  ))}
                </div>
                <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-slate-300">
                  {p.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <!-- Skills -->
        <section id="skills" class="mt-16">
          <h2 class="text-2xl font-semibold">Skills</h2>
          <div class="mt-5 grid gap-3 md:grid-cols-2">
            {SKILLS.map((s) => (
              <div class="rounded-2xl border border-slate-800 bg-slate-900/30 p-4 text-sm text-slate-200">
                {s}
              </div>
            ))}
          </div>
        </section>

        <!-- Contact -->
        <section id="contact" class="mt-16">
          <h2 class="text-2xl font-semibold">Contact</h2>
          <p class="mt-2 text-sm text-slate-300">
            Bisa hubungi saya lewat:
          </p>

          <div class="mt-5 grid gap-4 md:grid-cols-2">
            <a class="rounded-2xl border border-slate-800 bg-slate-900/30 p-4 hover:border-slate-700" href={PROFILE.contacts.telegram.href} target="_blank" rel="noreferrer">
              <div class="text-sm text-slate-300">Telegram</div>
              <div class="mt-1 font-semibold">{PROFILE.contacts.telegram.label}</div>
            </a>
            <a class="rounded-2xl border border-slate-800 bg-slate-900/30 p-4 hover:border-slate-700" href={PROFILE.contacts.whatsapp.href} target="_blank" rel="noreferrer">
              <div class="text-sm text-slate-300">WhatsApp</div>
              <div class="mt-1 font-semibold">{PROFILE.contacts.whatsapp.label}</div>
            </a>
            <a class="rounded-2xl border border-slate-800 bg-slate-900/30 p-4 hover:border-slate-700" href={PROFILE.contacts.email.href}>
              <div class="text-sm text-slate-300">Email</div>
              <div class="mt-1 font-semibold">{PROFILE.contacts.email.label}</div>
            </a>
            <a class="rounded-2xl border border-slate-800 bg-slate-900/30 p-4 hover:border-slate-700" href={PROFILE.contacts.github.href} target="_blank" rel="noreferrer">
              <div class="text-sm text-slate-300">GitHub</div>
              <div class="mt-1 font-semibold">{PROFILE.contacts.github.label}</div>
            </a>
          </div>
        </section>

        <footer class="mt-16 border-t border-slate-800 py-8 text-sm text-slate-400">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <span>© {new Date().getFullYear()} {PROFILE.name}</span>
            <span class="text-slate-500">Built with Astro + Tailwind • GitHub Pages</span>
          </div>
        </footer>
      </div>
    </main>

    <style is:global>
      @import "../styles/global.css";
    </style>
  </body>
</html>

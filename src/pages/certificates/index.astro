---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { CERTIFICATES } from '../../data/certificates';
---

<BaseLayout title="Certificates — Ikhtiar Hidayatullah" canonical="https://tiarh.github.io/certificates" ogImage="/og/home.png">
  <main class="relative min-h-screen">
    <div class="fixed inset-0 bg-grid opacity-40 pointer-events-none"></div>
    <div class="relative mx-auto max-w-4xl px-6 py-12">
      <SiteHeader />

      <section class="mt-12">
        <h1 class="text-4xl font-bold">Certificates & Training</h1>
        <p class="mt-2 text-slate-400">Ringkasan pelatihan dan sertifikat (akan diisi dari LinkedIn).</p>

        {CERTIFICATES.length === 0 ? (
          <div class="mt-8 rounded-2xl border border-slate-800 bg-slate-900/30 p-6 text-slate-300">
            Belum ada data sertifikat di website. Kirim daftar sertifikat (judul + issuer + link), nanti saya isi.
          </div>
        ) : (
          <div class="mt-8 grid gap-4">
            {CERTIFICATES.map((c) => (
              <div class="rounded-2xl border border-slate-800 bg-slate-900/30 p-6">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <div class="text-xl font-semibold">{c.title}</div>
                    <div class="text-slate-400">{c.issuer}</div>
                  </div>
                  {c.date && <div class="text-sm text-slate-500">{c.date}</div>}
                </div>
                {c.url && (
                  <div class="mt-3">
                    <a class="text-cyan-400 hover:text-cyan-300" href={c.url} target="_blank" rel="noreferrer">Lihat</a>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </section>

      <footer class="mt-20 border-t border-slate-800 py-8 text-sm text-slate-500">
        <a href="/" class="hover:text-cyan-400">← Home</a>
      </footer>
    </div>
  </main>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { PROJECTS } from '../../data/projects';
---

<BaseLayout title="Projects — Ikhtiar Hidayatullah" canonical="https://tiarh.github.io/projects" ogImage="/og/projects.png">
  <main class="relative min-h-screen">
    <div class="fixed inset-0 bg-grid opacity-40 pointer-events-none"></div>
    <div class="relative mx-auto max-w-5xl px-6 py-12">
      <SiteHeader />

      <section class="mt-12">
        <h1 class="text-4xl font-bold">Projects</h1>
        <p class="mt-2 text-slate-400">Case study & automation untuk NOC/ISP.</p>

        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {PROJECTS.map((p) => (
            <a
              href={`/projects/${p.slug}`}
              class="group rounded-2xl border border-slate-800 bg-slate-900/30 p-6 hover:border-cyan-500/30 hover:bg-slate-800/30 transition-all"
            >
              <div class="flex items-start justify-between gap-3">
                <h2 class="text-xl font-semibold group-hover:text-cyan-400 transition-colors">
                  {p.title}
                </h2>
                <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-300">
                  {p.status}
                </span>
              </div>
              <p class="mt-3 text-slate-300">{p.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {p.tags.map((t) => (
                  <span class="rounded-full bg-slate-800/70 px-3 py-1 text-xs text-slate-200">{t}</span>
                ))}
              </div>
              <div class="mt-6 text-sm text-cyan-400">Baca case study →</div>
            </a>
          ))}
        </div>
      </section>

      <footer class="mt-20 border-t border-slate-800 py-8 text-sm text-slate-500">
        <a href="/" class="hover:text-cyan-400">← Back</a>
      </footer>
    </div>
  </main>
</BaseLayout>

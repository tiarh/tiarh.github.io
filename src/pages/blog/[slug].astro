---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

export const prerender = true;

export function getStaticPaths() {
  const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
  return Object.entries(modules).map(([file, post]) => ({
    params: { slug: file.split('/').pop().replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
const fm = post.frontmatter;
const slug = Astro.params.slug;
---

<BaseLayout title={`${fm.title} — Blog`} description={fm.description} canonical={`https://tiarh.github.io/blog/${slug}`} ogImage={`/og/blog-${slug}.png`}>
  <main class="relative min-h-screen">
    <div class="fixed inset-0 bg-grid opacity-40 pointer-events-none"></div>
    <div class="relative mx-auto max-w-3xl px-6 py-12">
      <SiteHeader />

      <article class="prose prose-invert max-w-none mt-12">
        <a href="/blog" class="text-sm text-slate-400 hover:text-cyan-400">← Blog</a>
        <h1>{fm.title}</h1>
        <p class="text-slate-400">{new Date(fm.pubDate).toLocaleDateString('id-ID')}</p>
        <Content />
      </article>

      <footer class="mt-20 border-t border-slate-800 py-8 text-sm text-slate-500">
        <a href="/" class="hover:text-cyan-400">Home</a>
      </footer>
    </div>
  </main>
</BaseLayout>
